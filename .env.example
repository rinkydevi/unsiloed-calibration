# ── docker-compose environment ────────────────────────────────────────────────
# Copy to .env and fill in values before running docker compose up

# Generate with: openssl rand -base64 32
JWT_SECRET=

# Optional: override default postgres password
POSTGRES_PASSWORD=localdev

# Frontend origin — used by the backend for CORS
FRONTEND_URL=http://localhost:3000

# URL the *browser* uses to reach the API (must be host-reachable, not container name)
NEXT_PUBLIC_API_URL=http://localhost:3001

NODE_ENV=production
