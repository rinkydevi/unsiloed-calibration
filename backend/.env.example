# PostgreSQL connection string
# Local dev (docker-compose): postgresql://postgres:localdev@localhost:5432/unsiloed_calibration
# Railway/Render: copy from the database dashboard
DATABASE_URL="postgresql://postgres:localdev@localhost:5432/unsiloed_calibration"

# Generate with: openssl rand -base64 32
JWT_SECRET="dev-secret-change-in-prod"

PORT=3001
HOST=0.0.0.0

# Must match the deployed frontend origin (used for CORS)
FRONTEND_URL="http://localhost:3000"

NODE_ENV="development"
